SEEDANCE_API_KEY=
SEEDANCE_API_BASE_URL=
FAL_API_KEY=
FAL_API_BASE_URL=https://queue.fal.run
OUTPUT_DIR=outputs
POLL_INTERVAL_SECONDS=5
POLL_TIMEOUT_SECONDS=600
SEEDANCE_CREATE_PATH=/v1/video/generations
SEEDANCE_STATUS_PATH_TEMPLATE=/v1/video/generations/{id}
SEEDANCE_DOWNLOAD_PATH_TEMPLATE=/v1/video/generations/{id}/content
MOCK_SEEDANCE=false
MOCK_VIDEO_PROVIDER=false

# Frontend. No pongas API keys privadas en variables VITE_.
# Las claves privadas deben vivir en el backend/proxy.
VITE_API_BASE_URL=/api
